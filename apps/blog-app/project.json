{
  "name": "blog-app",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/blog-app/src",
  "prefix": "blog",
  "tags": ["type:app", "framework:angular", "scope:blog"],
  "targets": {
    "build": {
      "executor": "@analogjs/platform:vite",
      "options": {
        "configFile": "apps/blog-app/vite.config.ts",
        "main": "apps/blog-app/src/main.ts",
        "outputPath": "dist/apps/blog-app/client",
        "tsConfig": "apps/blog-app/tsconfig.app.json"
      },
      "defaultConfiguration": "production",
      "configurations": {
        "development": {
          "mode": "development"
        },
        "production": {
          "sourcemap": false,
          "mode": "production"
        }
      },
      "outputs": ["{workspaceRoot}/dist/apps/blog-app", "{workspaceRoot}/.vercel/output"]
    },
    "serve": {
      "executor": "@analogjs/platform:vite-dev-server",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "blog-app:build",
        "port": 3000
      },
      "configurations": {
        "development": {
          "buildTarget": "blog-app:build:development",
          "hmr": true
        },
        "production": {
          "buildTarget": "blog-app:build:production"
        }
      }
    },
    "preview": {
      "executor": "@nx/vite:preview-server",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "blog-app:build"
      },
      "configurations": {
        "development": {
          "buildTarget": "blog-app:build:development"
        },
        "production": {
          "buildTarget": "blog-app:build:production"
        }
      },
      "dependsOn": ["build"]
    }
  }
}
